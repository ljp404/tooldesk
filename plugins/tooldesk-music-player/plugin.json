    "music",
    "filesystem",
    "http"
  ],
  "publisher": "tooldesk",
  "sync": {
    "localStorageKeys": [
      "tooldesk-music-recent",
      "tooldesk-music-playlists"
    ]
  },
  "version": "0.1.0",
  "manifestVersion": 1,
  "sdkVersion": "1.0.0",
  "minHostVersion": "0.1.0",
