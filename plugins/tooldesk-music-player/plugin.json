{
  "accent": "pink",
  "caption": "播放本地音乐、云盘音乐和在线音乐。",
  "category": "life",
  "defaultAlias": "yy",
  "entry": "index.html",
  "icon": "assets/icon.svg",
  "id": "tooldesk-music-player",
  "keywords": [
    "bfq",
    "music",
    "yinyue",
    "yinyuebofangqi",
    "player",
    "mp3",
    "audio"
  ],
  "name": "音乐播放器",
