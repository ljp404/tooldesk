    "downloadOnlineMusic",
    "getAliyunToken",
    "getMusicCacheStats",
    "getMusicPlayerSettings",
    "getPluginStorageItem",
    "openPath",
    "resolveCloudPlayUrl",
    "resolveLocalPlayUrl",
    "resolveMusicCloudStoragePlayUrl",
    "resolveOnlinePlayUrl",
    "resolveTrackLyrics",
    "saveAliyunToken",
    "saveMusicPlayerSettings",
    "scanMusicFiles",
    "searchOnlineMusic",
    "setPluginStorageItem",
    "showOpenDialog",
    "uploadMusicCloudStorageFile",
    "validateMusicCloudStorage"
  ],
  "windowIcon": "assets/window-icon.png"
