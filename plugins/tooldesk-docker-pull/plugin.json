{
  "accent": "blue",
  "caption": "支持 Compose 或手动镜像清单，可在本机、SSH 远程拉取或导出服务器脚本。",
  "category": "dev",
  "defaultAlias": "jxlq",
  "entry": "index.html",
  "icon": "assets/icon.svg",
  "id": "tooldesk-docker-pull",
  "keywords": [
    "docker",
    "compose",
    "jingxianglaqu",
    "pull",
    "mirror",
    "ssh",
    "remote",
    "镜像",
    "容器",
    "拉取",
    "远程",
    "脚本"
  ],
  "manifestVersion": 1,
  "minHostVersion": "0.1.0",
  "name": "镜像拉取",
  "permissions": [
    "clipboard",
    "docker",
    "filesystem",
    "http",
    "ssh"
  ],
  "publisher": "tooldesk",
  "sdkVersion": "1.0.0",
  "capabilities": [
    "checkDockerAvailable",
    "copyText",
    "dockerImageExists",
    "dockerPullImage",
    "dockerTagImage",
    "getPluginStorageItem",
    "onSshExecOutput",
    "readTextFile",
    "runDockerCompose",
    "sendHttpRequest",
    "setPluginStorageItem",
    "showOpenDialog",
    "sshExec",
    "sshExecStream",
    "testSshConnection"
  ],
  "sync": {
    "localStorageKeys": [
      "tooldesk-docker-pull-manual-images",
      "tooldesk-docker-pull-mirrors",
      "tooldesk-docker-pull-mode",
      "tooldesk-docker-pull-source",
      "tooldesk-docker-pull-ssh-config"
    ]
  },
  "version": "0.2.1",
  "windowIcon": "assets/window-icon.png"
}
